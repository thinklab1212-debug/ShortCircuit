# ============================================================================
# ElectroKart Backend — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in active service keys.
# Ensure all required parameters meet Zod boundary formats defined in env.ts.
# ============================================================================

# Application Environment (development | staging | production)
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# MongoDB Atlas Connection
MONGODB_URI=mongodb://localhost:27017/electrokart

# JWT Token Credentials (Secrets must be at least 32 characters long)
JWT_ACCESS_SECRET=change_me_to_a_secure_long_32_character_access_key
JWT_REFRESH_SECRET=change_me_to_a_secure_long_32_character_refresh_key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Integration (Media Image Hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Integration (Payment Orders and Verification)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Resend Integration (Transactional Emails)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Short Circuit <noreply@shortcircuit.co.in>

# Rate Limiting Presets
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging & Docs Options
LOG_LEVEL=info
SWAGGER_ENABLED=true

# Default Administrative Account (Used by Seeder)
ADMIN_EMAIL=admin@electrokart.com
ADMIN_PASSWORD=AdminPass@12345
